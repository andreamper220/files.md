# Copy to .env and fill in before: docker compose up
#
#   cp .env.example .env

# Required for Telegram bot
BOT_API_TOKEN=

# Required for voice transcription (kie.ai)
KIE_API_KEY=

# Required for PWA ↔ server sync (/app in bot)
# Generate: openssl rand -base64 32   (or any long random string)
TOKENS_SALT=

# Public URLs (Docker on localhost)
APP_URL=http://localhost
API_URL=http://localhost

# Storage (paths inside the container — do not change unless you know why)
STORAGE_DIR=/app/storage
TOKENS_DIR=/app/tokens
CERT_DIR=

# 0 = unlimited storage quota for self-hosted use
STORAGE_QUOTA_KB=0

# Optional: comma-separated Telegram user IDs with unlimited quota
# UNLIMITED_QUOTA_IDS=
